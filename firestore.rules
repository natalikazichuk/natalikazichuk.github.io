rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() { return request.auth != null; }
    function myEmail()  { return request.auth.token.email; }

    // Батьки: лише власний документ (ключ = uid)
    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;
    }

    // Діти: доступ лише в межах своєї сім'ї (parentEmail == email батьків)
    match /children/{childId} {
      allow read:          if signedIn() && resource.data.parentEmail == myEmail();
      allow create:        if signedIn() && request.resource.data.parentEmail == myEmail();
      allow update, delete:if signedIn() && resource.data.parentEmail == myEmail();
    }

    // Герої: так само за parentEmail (тут зберігаються health та xp)
    match /heroes/{heroId} {
      allow read:          if signedIn() && resource.data.parentEmail == myEmail();
      allow create:        if signedIn() && request.resource.data.parentEmail == myEmail();
      allow update, delete:if signedIn() && resource.data.parentEmail == myEmail();
    }

    // Глобальний лічильник кодів героїв (HeroNNN)
    match /meta/{docId} {
      allow read, write: if signedIn();
    }
  }
}
